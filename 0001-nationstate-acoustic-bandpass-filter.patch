diff --git a/sound/core/acoustic_filter.c b/sound/core/acoustic_filter.c
new file mode 100644
index 000000000..d3cb93401
--- /dev/null
+++ b/sound/core/acoustic_filter.c
@@ -0,0 +1,293 @@
+// SPDX-License-Identifier: GPL-2.0-or-later
+/*
+ * Acoustic band-pass hardening filter ("Nationstate level filter pass").
+ *
+ * Applies a fixed band-pass (CONFIG_SND_NATIONSTATE_FILTER_LOW_HZ ..
+ * CONFIG_SND_NATIONSTATE_FILTER_HIGH_HZ) to every PCM stream passing through
+ * the ALSA core.  Implemented as a cascade of two RBJ biquads per channel:
+ * a 2nd-order Butterworth high-pass at the low cutoff followed by a 2nd-order
+ * Butterworth low-pass at the high cutoff.
+ *
+ * Everything is fixed point: the kernel must not use the FPU on the audio
+ * path, and biquad coefficients need sin()/cos(), so a small Bhaskara-I
+ * sine approximation is used to derive the coefficients at hw_params time.
+ *
+ * Supported sample formats are the little-endian signed integer formats real
+ * hardware uses (S16_LE and 32-bit containers: S32_LE, S24_LE).  Anything
+ * else is passed through untouched.
+ */
+#include <linux/slab.h>
+#include <linux/math64.h>
+#include <linux/minmax.h>
+#include <linux/unaligned.h>
+#include <linux/overflow.h>
+#include <sound/core.h>
+#include <sound/pcm.h>
+#include <sound/acoustic_filter.h>
+
+/* coefficient / sample-math fixed-point format */
+#define FILT_FRAC	27
+#define FILT_ONE	(1LL << FILT_FRAC)
+#define FILT_ROUND	(1LL << (FILT_FRAC - 1))
+
+/* 1/(2Q) for a Butterworth section, Q = 1/sqrt(2), in Q30 */
+#define INV_2Q_Q30	759250125LL	/* round(0.70710678 * 2^30) */
+
+/* pi family in Q16 */
+#define PI_Q16		205887LL
+#define HALFPI_Q16	102944LL
+#define TWOPI_Q16	411775LL
+
+/* 1.0 in Q30, used while designing coefficients before normalization */
+#define Q30_ONE		(1LL << 30)
+
+struct biquad_state {
+	s32 x1, x2;	/* previous inputs  */
+	s32 y1, y2;	/* previous outputs */
+};
+
+struct acoustic_chan {
+	struct biquad_state hp;	/* high-pass at the low cutoff  */
+	struct biquad_state lp;	/* low-pass at the high cutoff  */
+};
+
+struct acoustic_filter {
+	unsigned int rate;
+	unsigned int channels;
+
+	/* normalized coefficients (Q27); shared by all channels */
+	s64 hp_b0, hp_b1, hp_b2, hp_a1, hp_a2;
+	s64 lp_b0, lp_b1, lp_b2, lp_a1, lp_a2;
+
+	struct acoustic_chan chan[];	/* [channels] */
+};
+
+/*
+ * Bhaskara I sine approximation, accurate to ~0.2%.  @angle is in Q16
+ * radians; the result is in Q30 over [-1, 1].  Good enough for filter
+ * coefficient design and needs no table or FPU.
+ */
+static s64 fp_sin(s64 angle)
+{
+	s64 five_pisq, x, t, num, den, res;
+	int neg = 0;
+
+	/* reduce to [0, 2pi) */
+	angle %= TWOPI_Q16;
+	if (angle < 0)
+		angle += TWOPI_Q16;
+
+	/* sin(x + pi) = -sin(x): fold to [0, pi] */
+	if (angle > PI_Q16) {
+		angle -= PI_Q16;
+		neg = 1;
+	}
+	x = angle;
+
+	t = (x * (PI_Q16 - x)) >> 16;			/* Q16 */
+	five_pisq = 5 * ((PI_Q16 * PI_Q16) >> 16);	/* Q16 */
+
+	num = 16 * t;					/* Q16 */
+	den = five_pisq - 4 * t;			/* Q16 */
+	if (den <= 0)
+		return 0;
+
+	res = div_s64(num << 30, den);			/* Q30 */
+	return neg ? -res : res;
+}
+
+static s64 fp_cos(s64 angle)
+{
+	return fp_sin(angle + HALFPI_Q16);
+}
+
+/* normalize a Q30 coefficient by a0 (Q30), result in Q27 */
+static s64 norm_coeff(s64 coeff_q30, s64 a0_q30)
+{
+	return div_s64(coeff_q30 << FILT_FRAC, a0_q30);
+}
+
+static void design_filter(struct acoustic_filter *f, unsigned int rate)
+{
+	s64 w0_lo, w0_hi, cos0, sin0, alpha, a0;
+	s64 b0, b1, b2;
+	unsigned int low = CONFIG_SND_NATIONSTATE_FILTER_LOW_HZ;
+	unsigned int high = CONFIG_SND_NATIONSTATE_FILTER_HIGH_HZ;
+
+	f->rate = rate;
+
+	/* clamp the high cutoff below Nyquist so the design stays valid */
+	if (high > rate / 2)
+		high = rate / 2;
+
+	/* w0 = 2*pi*fc/fs, in Q16 radians; index needs no pi: 2pi*fc/fs */
+	w0_lo = div_u64(TWOPI_Q16 * low, rate);
+	w0_hi = div_u64(TWOPI_Q16 * high, rate);
+
+	/* ---- high-pass at the low cutoff ---- */
+	sin0 = fp_sin(w0_lo);
+	cos0 = fp_cos(w0_lo);
+	alpha = (sin0 * INV_2Q_Q30) >> 30;		/* Q30 */
+	a0 = Q30_ONE + alpha;				/* Q30 */
+	b0 = Q30_ONE + cos0;				/* (1 + cos)  Q30 */
+	f->hp_b0 = norm_coeff(b0 / 2, a0);
+	f->hp_b1 = norm_coeff(-b0, a0);
+	f->hp_b2 = norm_coeff(b0 / 2, a0);
+	f->hp_a1 = norm_coeff(-2 * cos0, a0);
+	f->hp_a2 = norm_coeff(Q30_ONE - alpha, a0);
+
+	/* ---- low-pass at the high cutoff ---- */
+	sin0 = fp_sin(w0_hi);
+	cos0 = fp_cos(w0_hi);
+	alpha = (sin0 * INV_2Q_Q30) >> 30;		/* Q30 */
+	a0 = Q30_ONE + alpha;				/* Q30 */
+	b1 = Q30_ONE - cos0;				/* (1 - cos)  Q30 */
+	b0 = b1 / 2;
+	b2 = b1 / 2;
+	f->lp_b0 = norm_coeff(b0, a0);
+	f->lp_b1 = norm_coeff(b1, a0);
+	f->lp_b2 = norm_coeff(b2, a0);
+	f->lp_a1 = norm_coeff(-2 * cos0, a0);
+	f->lp_a2 = norm_coeff(Q30_ONE - alpha, a0);
+}
+
+/* run one biquad on one integer sample; coefficients are Q27 */
+static s32 biquad_step(struct biquad_state *s, s32 in,
+		       s64 b0, s64 b1, s64 b2, s64 a1, s64 a2,
+		       s32 smin, s32 smax)
+{
+	s64 acc;
+	s32 out;
+
+	acc = b0 * in + b1 * s->x1 + b2 * s->x2 - a1 * s->y1 - a2 * s->y2;
+	acc = (acc + FILT_ROUND) >> FILT_FRAC;
+	out = clamp_t(s64, acc, smin, smax);
+
+	s->x2 = s->x1;
+	s->x1 = in;
+	s->y2 = s->y1;
+	s->y1 = out;
+	return out;
+}
+
+static s32 filter_sample(struct acoustic_filter *f, struct acoustic_chan *c,
+			 s32 in, s32 smin, s32 smax)
+{
+	s32 v;
+
+	v = biquad_step(&c->hp, in, f->hp_b0, f->hp_b1, f->hp_b2,
+			f->hp_a1, f->hp_a2, smin, smax);
+	v = biquad_step(&c->lp, v, f->lp_b0, f->lp_b1, f->lp_b2,
+			f->lp_a1, f->lp_a2, smin, smax);
+	return v;
+}
+
+/* fetch/store one little-endian sample of @bps bytes */
+static s32 load_sample(const u8 *p, int bps)
+{
+	if (bps == 2)
+		return (s16)get_unaligned_le16(p);
+	return (s32)get_unaligned_le32(p);
+}
+
+static void store_sample(u8 *p, int bps, s32 v)
+{
+	if (bps == 2)
+		put_unaligned_le16((u16)v, p);
+	else
+		put_unaligned_le32((u32)v, p);
+}
+
+static struct acoustic_filter *get_filter(struct snd_pcm_substream *substream)
+{
+	struct snd_pcm_runtime *runtime = substream->runtime;
+	struct acoustic_filter *f = runtime->acoustic_filter;
+	unsigned int channels = runtime->channels;
+
+	if (f && f->channels == channels) {
+		if (f->rate != runtime->rate)
+			design_filter(f, runtime->rate);
+		return f;
+	}
+
+	/* channel count changed (or first use): (re)allocate */
+	kfree(f);
+	f = kzalloc(struct_size(f, chan, channels), GFP_KERNEL);
+	if (!f) {
+		runtime->acoustic_filter = NULL;
+		return NULL;
+	}
+	f->channels = channels;
+	design_filter(f, runtime->rate);
+	runtime->acoustic_filter = f;
+	return f;
+}
+
+int snd_acoustic_filter_apply(struct snd_pcm_substream *substream, int channel,
+			      void *data, unsigned long bytes)
+{
+	struct snd_pcm_runtime *runtime = substream->runtime;
+	struct acoustic_filter *f;
+	unsigned int channels = runtime->channels;
+	bool interleaved;
+	int width, bps, ch;
+	s32 smin, smax;
+	unsigned long n, i;
+	u8 *p = data;
+
+	if (!data || !bytes || !channels)
+		return 0;
+
+	/* only little-endian signed integer formats are filtered */
+	if (!snd_pcm_format_signed(runtime->format) ||
+	    !snd_pcm_format_little_endian(runtime->format))
+		return 0;
+
+	width = snd_pcm_format_width(runtime->format);
+	bps = snd_pcm_format_physical_width(runtime->format) / 8;
+	if (bps != 2 && bps != 4)
+		return 0;		/* e.g. packed S24_3LE: pass through */
+
+	/* sample value range for the logical width (S24_LE: 24-bit in 32) */
+	smax = (width >= 32) ? S32_MAX : ((1 << (width - 1)) - 1);
+	smin = (width >= 32) ? S32_MIN : -(1 << (width - 1));
+
+	f = get_filter(substream);
+	if (!f)
+		return -ENOMEM;
+
+	interleaved =
+		runtime->access == SNDRV_PCM_ACCESS_RW_INTERLEAVED ||
+		runtime->access == SNDRV_PCM_ACCESS_MMAP_INTERLEAVED;
+
+	if (interleaved) {
+		n = bytes / ((unsigned long)bps * channels);
+		for (i = 0; i < n; i++) {
+			for (ch = 0; ch < channels; ch++, p += bps) {
+				s32 v = load_sample(p, bps);
+
+				v = filter_sample(f, &f->chan[ch], v, smin, smax);
+				store_sample(p, bps, v);
+			}
+		}
+	} else {
+		/* one channel's contiguous samples */
+		if (channel < 0 || channel >= (int)channels)
+			return 0;
+		n = bytes / bps;
+		for (i = 0; i < n; i++, p += bps) {
+			s32 v = load_sample(p, bps);
+
+			v = filter_sample(f, &f->chan[channel], v, smin, smax);
+			store_sample(p, bps, v);
+		}
+	}
+
+	return 0;
+}
+
+void snd_acoustic_filter_free(struct snd_pcm_runtime *runtime)
+{
+	kfree(runtime->acoustic_filter);
+	runtime->acoustic_filter = NULL;
+}
