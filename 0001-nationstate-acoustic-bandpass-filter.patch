diff --git a/sound/core/pcm_native.c b/sound/core/pcm_native.c
index 302643c1c..c4ab151a5 100644
--- a/sound/core/pcm_native.c
+++ b/sound/core/pcm_native.c
@@ -19,6 +19,7 @@
 #include <sound/control.h>
 #include <sound/info.h>
 #include <sound/pcm.h>
+#include <sound/acoustic_filter.h>
 #include <sound/pcm_params.h>
 #include <sound/timer.h>
 #include <sound/minors.h>
@@ -537,6 +538,11 @@ static int fixup_unreferenced_params(struct snd_pcm_substream *substream,
 		if (!hw_support_mmap(substream))
 			params->info &= ~(SNDRV_PCM_INFO_MMAP |
 					  SNDRV_PCM_INFO_MMAP_VALID);
+#ifdef CONFIG_SND_NATIONSTATE_FILTER
+		/* never advertise mmap: force the filtered read/write path */
+		params->info &= ~(SNDRV_PCM_INFO_MMAP |
+				  SNDRV_PCM_INFO_MMAP_VALID);
+#endif
 	}
 
 	err = snd_pcm_ops_ioctl(substream,
@@ -574,6 +580,27 @@ int snd_pcm_hw_refine(struct snd_pcm_substream *substream,
 	if (err < 0)
 		return err;
 
+#ifdef CONFIG_SND_NATIONSTATE_FILTER
+	/*
+	 * The acoustic band-pass hardening filter runs in the read/write copy
+	 * path.  mmap access lets user space (PulseAudio, PipeWire, JACK)
+	 * touch the DMA buffer directly and bypass it, so deny the mmap access
+	 * modes here: clients then fall back to read/write transfers and the
+	 * pass-band becomes unbypassable.  Devices that only support mmap
+	 * access will fail to open with this option enabled.
+	 */
+	{
+		struct snd_mask *amask =
+			hw_param_mask(params, SNDRV_PCM_HW_PARAM_ACCESS);
+
+		snd_mask_reset(amask, SNDRV_PCM_ACCESS_MMAP_INTERLEAVED);
+		snd_mask_reset(amask, SNDRV_PCM_ACCESS_MMAP_NONINTERLEAVED);
+		snd_mask_reset(amask, SNDRV_PCM_ACCESS_MMAP_COMPLEX);
+		if (snd_mask_empty(amask))
+			return -EINVAL;
+	}
+#endif
+
 	params->rmask = 0;
 
 	return 0;
