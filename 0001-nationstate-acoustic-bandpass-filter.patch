diff --git a/include/sound/acoustic_filter.h b/include/sound/acoustic_filter.h
new file mode 100644
index 000000000..5619a7b33
--- /dev/null
+++ b/include/sound/acoustic_filter.h
@@ -0,0 +1,59 @@
+/* SPDX-License-Identifier: GPL-2.0-or-later */
+/*
+ * Acoustic band-pass hardening filter ("Nationstate level filter pass").
+ *
+ * Enforces a fixed audio pass-band (CONFIG_SND_NATIONSTATE_FILTER_LOW_HZ ..
+ * CONFIG_SND_NATIONSTATE_FILTER_HIGH_HZ) on every PCM stream that flows
+ * through the ALSA core.  Because PulseAudio, PipeWire and JACK all sit on
+ * top of the ALSA kernel PCM layer, filtering here covers all of them; the
+ * pass-band cannot be reconfigured or bypassed from user space.
+ *
+ * The threat model is acoustic covert/side channels (ultrasonic beacons,
+ * near-ultrasonic exfiltration, infrasonic side channels).  This is a DSP
+ * band-pass: it *does* run code on the sample stream.  There is no way to
+ * remove out-of-band energy from a digital stream without processing it.
+ */
+#ifndef __SOUND_ACOUSTIC_FILTER_H
+#define __SOUND_ACOUSTIC_FILTER_H
+
+struct snd_pcm_substream;
+struct snd_pcm_runtime;
+
+#ifdef CONFIG_SND_NATIONSTATE_FILTER
+
+/**
+ * snd_acoustic_filter_apply - band-pass a chunk of PCM data in place
+ * @substream: the PCM substream the data belongs to
+ * @channel:   channel index for non-interleaved access; ignored (0) for
+ *             interleaved access where @data holds all channels
+ * @data:      pointer into the DMA buffer holding the samples to filter
+ * @bytes:     number of bytes at @data to process
+ *
+ * Called from the PCM copy path for both playback (after the data has been
+ * copied into the DMA buffer) and capture (before the data is handed to user
+ * space).  Filtering is done in place.  Unsupported sample formats are passed
+ * through unmodified.  Returns 0 on success or a negative errno on allocation
+ * failure.
+ */
+int snd_acoustic_filter_apply(struct snd_pcm_substream *substream, int channel,
+			      void *data, unsigned long bytes);
+
+/* release per-substream filter state; called from snd_pcm_detach_substream() */
+void snd_acoustic_filter_free(struct snd_pcm_runtime *runtime);
+
+#else /* !CONFIG_SND_NATIONSTATE_FILTER */
+
+static inline int snd_acoustic_filter_apply(struct snd_pcm_substream *substream,
+					    int channel, void *data,
+					    unsigned long bytes)
+{
+	return 0;
+}
+
+static inline void snd_acoustic_filter_free(struct snd_pcm_runtime *runtime)
+{
+}
+
+#endif /* CONFIG_SND_NATIONSTATE_FILTER */
+
+#endif /* __SOUND_ACOUSTIC_FILTER_H */
