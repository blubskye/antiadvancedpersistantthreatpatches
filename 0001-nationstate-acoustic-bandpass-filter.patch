+config SND_NATIONSTATE_FILTER
+	bool "Nationstate level filter pass (acoustic band-pass hardening)"
+	depends on SND_PCM
+	# SND_PCSP "select"s SND_PCM, so the pcspkr exclusion is expressed
+	# here rather than on SND_PCSP to avoid a recursive Kconfig dependency.
+	depends on SND_PCSP=n
+	help
+	  Enforce a fixed audio pass-band on every PCM stream that flows
+	  through the ALSA core.  All frequencies outside the configured band
+	  are attenuated by a band-pass filter (a high-pass at the lower cutoff
+	  cascaded with a low-pass at the upper cutoff) applied to both
+	  playback and capture.
+
+	  Because PulseAudio, PipeWire and JACK all run on top of the ALSA
+	  kernel PCM layer, the filter covers all of them, and the pass-band
+	  cannot be reconfigured or bypassed from user space.  To keep it
+	  unbypassable, mmap access to PCM devices is disabled while this
+	  option is set, forcing all clients through the filtered read/write
+	  path; devices that only support mmap access will fail to open.
+
+	  This is intended as hardening against acoustic covert and side
+	  channels (ultrasonic beacons, near-ultrasonic exfiltration,
+	  infrasonic side channels).  It is a DSP filter: it processes the
+	  sample stream and adds CPU cost on the audio path.
+
+	  Enabling this disables the PC speaker drivers (INPUT_PCSPKR and
+	  SND_PCSP), whose square-wave output has harmonics above the band
+	  that software cannot remove.
+
+	  If unsure, say N.
+
+config SND_NATIONSTATE_FILTER_LOW_HZ
+	int "Lower cutoff frequency (Hz)"
+	depends on SND_NATIONSTATE_FILTER
+	default 16
+	help
+	  Frequencies below this are attenuated (high-pass cutoff).
+
+config SND_NATIONSTATE_FILTER_HIGH_HZ
+	int "Upper cutoff frequency (Hz)"
+	depends on SND_NATIONSTATE_FILTER
+	default 10000
+	help
+	  Frequencies above this are attenuated (low-pass cutoff).  The value
+	  is clamped below the Nyquist frequency of each stream's sample rate.
+
 config SND_VMASTER
 	bool
 
